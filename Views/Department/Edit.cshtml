@using Task_Day_2_ASP.Models.ViewModel
@model DepartmentWithDetails
@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Department</h1>

<form method="post" asp-controller="Department" asp-action="SaveEdit">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MrgName"></label>
        <input asp-for="MrgName" class="form-control" />
        <span asp-validation-for="MrgName" class="text-danger"></span>
    </div>

    <input type="submit" value="Save" class="btn btn-primary mt-3" />
</form>

<a asp-action="Index">Back</a>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}