@using Task_Day_2_ASP.Models.Entities

@model List<Student>

<table class="table table-hover table-bordered">
	<tr>
		<th>Number</th>
		<th>Name</th>
		<th>Age</th>
	</tr>
	@foreach (var item in Model) 							
	{
		<tr>
			<td>@item.Id</td>
			<td>@item.Name</td>
			<td>@item.Age</td>
		</tr>
	}
</table>

